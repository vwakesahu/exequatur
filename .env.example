# ---- network ----
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ---- accounts ----
# owner key behind the user's MetaMask smart account (the delegator)
DELEGATOR_PRIVATE_KEY=
# primary agent EOA (the delegate / redeemer)
AGENT_PRIVATE_KEY=
# sub-agent EOA (the redelegate / worker)
WORKER_PRIVATE_KEY=
# policy service signer — its ADDRESS is baked into AttestationEnforcer terms
POLICY_PRIVATE_KEY=

# ---- demo targets ----
MERCHANT_ADDRESS=
ATTACKER_ADDRESS=

# ---- deployed contracts (filled by setup) ----
MOCK_USDC_ADDRESS=
ATTESTATION_ENFORCER_ADDRESS=

# ---- Venice (M4 — real policy verdict) ----
# Leave VENICE_API_KEY empty to use the deterministic stub (offline, default).
# Set it (in sdk/.env or this repo-root .env — both are loaded & gitignored) to gate every payment
# with real Venice. The account needs inference credits (add at https://venice.ai/settings/api or
# stake VVV) — without credits the API returns 402 and the firewall fails CLOSED (denies).
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=qwen3-4b
